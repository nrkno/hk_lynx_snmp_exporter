    SYNTAX TypePresetsSaveAs
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "saves the current user settings as a user preset, that saved user preset can be later loaded again into the current settings"
    ::= { paramEntry 79 }

presetsCurrentSettingsBasedOn OBJECT-TYPE
    SYNTAX TypePresetsCurrentSettingsBasedOn
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "Current Settings based on"
    ::= { paramEntry 80 }

presetsLoadToCurrent OBJECT-TYPE
    SYNTAX TypePresetsCurrentSettingsBasedOn
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "Load a copy of the specified UserPreset as the current settings.<br>The current settings of the complete product will be overwritten. Reading the current value of this parameter tells you which of the available presets has been loaded last.<br>NOTE that the current settings can potentially differ from the loaded preset because individual changes may have been applied at any time."
    ::= { paramEntry 81 }

presetsName0 OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "name of user preset 0"
    ::= { paramEntry 82 }

presetsName1 OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "name of user preset 1"
    ::= { paramEntry 83 }

presetsName2 OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "name of user preset 2"
    ::= { paramEntry 84 }

presetsName3 OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "name of user preset 3"
    ::= { paramEntry 85 }

presetsName4 OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "name of user preset 4"
    ::= { paramEntry 86 }

presetsName5 OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "name of user preset 5"
    ::= { paramEntry 87 }

presetsName6 OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "name of user preset 6"
    ::= { paramEntry 88 }

presetsName7 OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "name of user preset 7"
    ::= { paramEntry 89 }

delayAudioSDIOutGang OBJECT-TYPE
    SYNTAX OnOffValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "Gang-Mode: Couple all SDI Out Delay values (modify all delay controls synchronously)"
    ::= { paramEntry 90 }

delayAudioAESOutGang OBJECT-TYPE
    SYNTAX OnOffValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "Gang-Mode: Couple all AES Out Delay values (modify all delay controls synchronously)"
    ::= { paramEntry 91 }

eventPrimaryPowermissingSNMP OBJECT-TYPE
    SYNTAX TypeEventPrimaryPowermissingSNMP
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "SNMP Trap for  Event: Primary Power missing"
    ::= { paramEntry 93 }

eventRedundantPowermissingSNMP OBJECT-TYPE
    SYNTAX TypeEventPrimaryPowermissingSNMP
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "SNMP Trap for  Event: Redundant Power missing"
    ::= { paramEntry 94 }

eventFanFailureSNMP OBJECT-TYPE
    SYNTAX TypeEventPrimaryPowermissingSNMP
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "SNMP Trap for  Event: Fan Failure"
    ::= { paramEntry 95 }

eventReferenceNoInputSNMP OBJECT-TYPE
    SYNTAX TypeEventPrimaryPowermissingSNMP
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "SNMP Trap for  Event: Reference No Input"
    ::= { paramEntry 96 }

eventSDIInput1NoInputSNMP OBJECT-TYPE
    SYNTAX TypeEventPrimaryPowermissingSNMP
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "SNMP Trap for  Event: SDI Input 1 No Input"
    ::= { paramEntry 97 }

eventCouldnotlocktoReferenceSNMP OBJECT-TYPE
    SYNTAX TypeEventPrimaryPowermissingSNMP
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "SNMP Trap for  Event: Could not lock to Reference"
    ::= { paramEntry 98 }

eventCouldnotlocktoSDIInput1SNMP OBJECT-TYPE
    SYNTAX TypeEventPrimaryPowermissingSNMP
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "SNMP Trap for  Event: Could not lock to SDI Input 1"
    ::= { paramEntry 99 }

metaVPIDStandardConform OBJECT-TYPE
    SYNTAX OnOffValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "Specify whether the line for VPID insertion into Field2 is set according to the SMPTE 352M-2002 Standard or not."
    ::= { paramEntry 100 }

sDIIn13GFormat OBJECT-TYPE
    SYNTAX TypeSDIIn13GFormat
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "For 3G-SDI input streams, this value displays the mapping format according to SMPTE 425."
    ::= { paramEntry 101 }

sDIIn1DeembedFrom3GLevelB OBJECT-TYPE
    SYNTAX TypeSDIIn1DeembedFrom3GLevelB
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "For 3G-SDI input streams in Dual-Link or Dual-Stream mapping, the audio-deembedder will work on the selected stream only."
    ::= { paramEntry 102 }

out13GFormat OBJECT-TYPE
    SYNTAX TypeOut13GFormat
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "For 3G-SDI output streams, this parameter shows the current format."
    ::= { paramEntry 103 }

out1SDI3GTransport OBJECT-TYPE
    SYNTAX TypeOut1SDI3GTransport
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "For 3G-SDI output streams, select the desired transport format.<br>The default behaviour (auto) will chose the same transport format as the input stream, resp. fall back to <i>Level A</i>."
    ::= { paramEntry 104 }

out1Embed3GLevelBStreamSelect OBJECT-TYPE
    SYNTAX TypeOut1Embed3GLevelBStreamSelect
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "For 3G-SDI multi-stream output formats, specify which streams to embed audio into.<br>By default, the same audio content is embedded into both streams. Note: if only one stream is specified, then the same groups will be removed from the other stream.<br>NOTE: see also parameter OutX/EmbedStreamCP."
    ::= { paramEntry 105 }

out1Embed3GLevelBCPStreamSelect OBJECT-TYPE
    SYNTAX TypeOut1Embed3GLevelBStreamSelect
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION "For 3G-SDI multi-stream output formats, specify which streams to embed audio control packets into.<br>By default, the audio control packets are embedded into stream A only.<br>NOTE: see also parameter OutX/EmbedStream."
    ::= { paramEntry 106 }

sFPOutPower OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "displays the average output power of detected SFP-Module ."
    ::= { paramEntry 107 }

sFPWavelength OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "displays the wavelength of detected SFP-Module ."
    ::= { paramEntry 108 }

sNumber OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION "Serial Number"
    ::= { paramEntry 109 }

-- Parameter table
paramTable OBJECT-TYPE
    SYNTAX SEQUENCE OF ParamEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION "Table of PVD5800-O parameters"
    ::= { sw762 1 }

paramEntry OBJECT-TYPE
    SYNTAX ParamEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION "A row in the table of PVD5800-O parameters"
    INDEX { IMPLIED position }
    ::= { paramTable 1 }

ParamEntry ::= SEQUENCE {
    typeName DisplayString,
    displayName DisplayString,
    position OCTET STRING,
    uptime TimeTicks,
    type DisplayString,
    version DisplayString,
    factoryReset TypeFactoryReset,
    lock OnOffValue,
    locate OnOffValue,
    backpanelStatus TypeBackpanelStatus,
    boardID Integer32,
    outStandard TypeOutStandard,
    inStandard TypeOutStandard,
    delayVideoUserMode TypeDelayVideoUserMode,
    delayVideoFrames Integer32,
    delayVideoLines Integer32,
    delayVideoPixels Integer32,
    delayVideoTotalMs FixedPointValue3,
    referenceLock TypeReferenceLock,
    referenceStatus TypeOutStandard,
    referenceSource TypeReferenceSource,
    freqPreselect TypeFreqPreselect,
    freq TypeFreq,
    gPIFunc TypeGPIFunc,
    gPI2Func TypeGPIFunc,
    inputToRefTolerance OnOffValue,
    syncMode1 TypeSyncMode1,
    inputFreezeSDI1 TypeInputFreezeSDI1,
    syncSDIIn1 OnOffValue,
    out1ApertureEnable OnOffValue,
    out1ApertureLevel Integer32,
    out1HBlank OnOffValue,
    out1VBlank OnOffValue,
    out1HFlip OnOffValue,
    out1Gain Integer32,
    out1Saturation Integer32,
    out1BlackLevel FixedPointValue1,
    out1Hue FixedPointValue1,
    out1TestPatternSelect TypeOut1TestPatternSelect,
    out1TestPatternStd TypeOut1TestPatternStd,
    out1TestPatternOn OnOffValue,
    out1IfNoInput TypeOut1IfNoInput,
    input1OpticalSignalQuality FixedPointValue1,
    sFPModuleType1 DisplayString,
    sFPModulePartNumber1 DisplayString,
    sDIIn1SourceType TypeSDIIn1SourceType,
    audioDelayAESOut FixedPointValue2,
    audioDelaySDI1 FixedPointValue2,
    audioDelaySDIOut1 FixedPointValue2,
    presetsGPIOn TypePresetsGPIOn,
    presetsGPIOff TypePresetsGPIOn,
    presetsGPIOffOn TypePresetsGPIOn,
    presetsGPIOnOn TypePresetsGPIOn,
    inputToRefDelay1H Integer32,
    inputToRefDelay1V Integer32,
    out1ClipHeadroom OnOffValue,
    out1FreezeMode TypeOut1FreezeMode,
    out1TotalProcTime FixedPointValue3,
    statusColor TypeStatusColor,
    statusColorRGB DisplayString,
    statusText DisplayString,
    eventPrimaryPowermissing OnOffValue,
    eventRedundantPowermissing OnOffValue,
    eventFanFailure OnOffValue,
    eventReferenceNoInput OnOffValue,
    eventSDIInput1NoInput OnOffValue,
    eventCouldnotlocktoReference OnOffValue,
    eventCouldnotlocktoSDIInput1 OnOffValue,
    presetsNumber Integer32,
    presetsActive TypePresetsGPIOn,
    presetsSaveAs TypePresetsSaveAs,
    presetsCurrentSettingsBasedOn TypePresetsCurrentSettingsBasedOn,
    presetsLoadToCurrent TypePresetsCurrentSettingsBasedOn,
    presetsName0 DisplayString,
    presetsName1 DisplayString,
    presetsName2 DisplayString,
    presetsName3 DisplayString,
    presetsName4 DisplayString,
    presetsName5 DisplayString,
    presetsName6 DisplayString,
    presetsName7 DisplayString,
    delayAudioSDIOutGang OnOffValue,
    delayAudioAESOutGang OnOffValue,
    eventPrimaryPowermissingSNMP TypeEventPrimaryPowermissingSNMP,
    eventRedundantPowermissingSNMP TypeEventPrimaryPowermissingSNMP,
    eventFanFailureSNMP TypeEventPrimaryPowermissingSNMP,
    eventReferenceNoInputSNMP TypeEventPrimaryPowermissingSNMP,
    eventSDIInput1NoInputSNMP TypeEventPrimaryPowermissingSNMP,
    eventCouldnotlocktoReferenceSNMP TypeEventPrimaryPowermissingSNMP,
    eventCouldnotlocktoSDIInput1SNMP TypeEventPrimaryPowermissingSNMP,
    metaVPIDStandardConform OnOffValue,
    sDIIn13GFormat TypeSDIIn13GFormat,
    sDIIn1DeembedFrom3GLevelB TypeSDIIn1DeembedFrom3GLevelB,
    out13GFormat TypeOut13GFormat,
    out1SDI3GTransport TypeOut1SDI3GTransport,
    out1Embed3GLevelBStreamSelect TypeOut1Embed3GLevelBStreamSelect,
    out1Embed3GLevelBCPStreamSelect TypeOut1Embed3GLevelBStreamSelect,
    sFPOutPower DisplayString,
    sFPWavelength DisplayString,
    sNumber DisplayString }

