        eventCouldnotlocktoSDIInput1,
        presetsNumber,
        presetsActive,
        presetsSaveAs,
        presetsCurrentSettingsBasedOn,
        presetsLoadToCurrent,
        presetsName0,
        presetsName1,
        presetsName2,
        presetsName3,
        presetsName4,
        presetsName5,
        presetsName6,
        presetsName7,
        delayAudioSDIOutGang,
        delayAudioAESOutGang,
        eventPrimaryPowermissingSNMP,
        eventRedundantPowermissingSNMP,
