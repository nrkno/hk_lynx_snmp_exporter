        out1VBlank,
        out1HFlip,
        out1Gain,
        out1Saturation,
        out1BlackLevel,
        out1Hue,
        out1TestPatternSelect,
        out1TestPatternStd,
        out1TestPatternOn,
        out1IfNoInput,
        input1OpticalSignalQuality,
        sFPModuleType1,
        sFPModulePartNumber1,
        sDIIn1SourceType,
        audioDelayAESOut,
        audioDelaySDI1,
        audioDelaySDIOut1,
        presetsGPIOn,
        presetsGPIOff,
        presetsGPIOffOn,
        presetsGPIOnOn,
        inputToRefDelay1H,
        inputToRefDelay1V,
        out1ClipHeadroom,
        out1FreezeMode,
        out1TotalProcTime,
        statusColor,
        statusColorRGB,
        statusText,
        eventPrimaryPowermissing,
        eventRedundantPowermissing,
        eventFanFailure,
        eventReferenceNoInput,
